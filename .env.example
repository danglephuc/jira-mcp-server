# Jira server URL (e.g. https://your-domain.atlassian.net for Cloud)
JIRA_URL=https://your-domain.atlassian.net

# Jira Cloud: email + API token (recommended)
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-api-token-here

# Jira Server / Data Center: username + password (or PAT token)
# JIRA_USERNAME=your-username
# JIRA_PASSWORD=your-password

# You can use email+token for Cloud or username+password for Server/DC.
# If JIRA_EMAIL and JIRA_API_TOKEN are set, they take priority.

# Optional
# MAX_TOKENS=50000
# PREFIX=jira_
# ENABLE_TOOLSETS=all
# JIRA_API_VERSION=2
